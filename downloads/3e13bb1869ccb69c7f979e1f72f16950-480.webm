      self.find('svg.feather').removeClass('active');
      self.siblings().find('svg.feather').removeClass('active');
    }

    else if (data.status == 200 && type == 'down' && data.type == 'added_dislike'){
      self.find('span').text((data.down));
      self.find('svg.feather').addClass('active');
      $('[data-reply-likes="'+reply_id+'"]').find('span').text((data.up));
      self.siblings().find('svg.feather').removeClass('active');
    }

    else if (data.status == 200 && type == 'down' && data.type == 'deleted_dislike'){
      self.find('span').text((data.down));
      self.find('svg.feather').removeClass('active');
      $('[data-reply-likes="'+reply_id+'"]').find('span').text((data.up));
      self.siblings().find('svg.feather').removeClass('active');
    }

    else{
      Swal.fire(
         'Error!',
         'Something went wrong.Please try again later!',
         'error'
       );
    }
  })
  .fail(function() {
    console.log("error");
  })
}

function pt_hide_announcement(id){
  if (!id) { return false; }
  $("#announcement-"+id).slideUp('fast',function(){
    $(this).remove();
    $.post('https://bondagevalley.cc/aj/main/hide-announcement', {id: id}, function(data, textStatus, xhr) { /* pass */ });
  })
}

function pay_to_see(video_id,price,type = 'buy') {
  PayUsingWallet(type,'show',video_id,price);
  return false;

  $('.p_t_show_btn_').attr('disabled', 'true');

  if (type == 'rent') {
    $('.p_t_show_btn_rent').text("Please wait..");
    $('.p_t_show_btn_rent').text("Rent $"+price);
    PT_ShowMethods('rent',video_id,price);
  }
  else{
    $('.p_t_show_btn_buy').text("Please wait..");
    $('.p_t_show_btn_buy').text("Purchase $"+price);
    PT_ShowMethods('pay',video_id,price);
  }

  $('.p_t_show_btn_').removeAttr('disabled');
}

function PT_ShowMethods(type,video_id = 0,price = 0,user_id = 0) {
  $.post('https://bondagevalley.cc/aj/wallet/get_modal',{type:type,video_id:video_id,price:price,user_id:user_id}, function(data, textStatus, xhr) {
    if (data.status == 200) {
      $('.payment_method').html(data.html);
      $(".payment_notes").hide(400);
      $('#pay-go-pro').modal({
            show: true
        });
      /* crypto auto ctrl */
      if(price<25) {
        $('#crypto-auto-cur-select option[value="BTC"]').prop('disabled','disabled')
      }
      else {
        $('#crypto-auto-cur-select option[value="BTC"]').prop('disabled',false)
      }
      /* cc ctrl */
      if(price < 50) {
        $('.btn-cc').attr('disabled',true);
        $('.btn-cc .btn-pm-label').append("(Only for 1 year sub)");
      }
    }
    if (type == 'subscribe') {
      $('.modal-title').html("Choose a payment method");
      $('.subscribe-id-'+user_id).find('span').text("Subscribe");
      $('.subscribe-id-'+user_id).removeAttr('disabled');
      $("#perfectmoney-button").attr("href", $("#perfectmoney-button").attr("href").replace(/amount=[0-9]+/g, "amount="+price));
    }
    if(type == '1day_promo') {
      $('.modal-title').html("Get a 1 day access for free!");
    }
  }).fail(function(jqXHR, textStatus, errorThrown)
    {
    //alert(textStatus);
  });
}

