            <script type="text/javascript">

         var myTimeout;

         function show_gif(self,gif) {
           if (gif && gif != '') {
             myTimeout = setTimeout(function() {
                 //$(self).append('<img src="'+gif+'">');
                $(self).append('<video class="vid-prv" loop muted preload="none" autoplay><source src="'+gif+'" type="video/webm"></video>');
             }, 500);
           }
         }

         function hide_gif(self) {
           $(self).find('video').remove();
           clearTimeout(myTimeout);
         }
         function block_user(user_id,self,redirect = true) {
           $.post('https://bondagevalley.cc/aj/user/block?hash=' + $('.main_session').val(), {user_id: user_id}, function(data, textStatus, xhr) {
             if (redirect == true) {
               location.reload();
             }
             else{
               $(self).find('span').text(data.message);
             }
           });
         }

      </script>

